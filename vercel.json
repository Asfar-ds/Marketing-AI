{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/main.py" },
    { "source": "/static/(.*)", "destination": "public/$1" },
    { "source": "/(.*)", "destination": "public/index.html" }
  ]
}
